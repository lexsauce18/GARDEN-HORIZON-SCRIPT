-- 2. SMART HARVEST ENGINE (DETECTS SINGLE VS MULTI HARVEST)
local function HarvestTarget(targetObj, parentName)
    local p = game.Players.LocalPlayer
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    local rawUuid = targetObj:GetAttribute("Uuid")
    if not rawUuid then return end
    
    local anchorIndex = targetObj:GetAttribute("GrowthAnchorIndex")
    local cleanUuid = string.split(rawUuid, ":")[1]

    local anchor = targetObj:FindFirstChild("PlantAnchor") or targetObj:FindFirstChild("FruitAnchor")
    if not anchor and targetObj.Parent then
        anchor = targetObj.Parent:FindFirstChild("PlantAnchor") or targetObj.Parent:FindFirstChild("FruitAnchor")
    end
    
    if anchor then
        char.HumanoidRootPart.CFrame = CFrame.new(anchor.Position + Vector3.new(0, 1.5, 2), anchor.Position)
        task.wait(0.1)
        
        local args = {}
        if anchorIndex then
            args = { { { Uuid = cleanUuid, GrowthAnchorIndex = anchorIndex } } }
        else
            args = { { { Uuid = cleanUuid } } }
        end
        
        HarvestRemote:FireServer(unpack(args))
        task.wait(0.2) 
    end
end

-- 3. VALIDATION LOGIC
local function ProcessCollect(obj, parentName)
    if obj:GetAttribute("FullyGrown") ~= true then return end
    if obj:GetAttribute("Favorited") == true then return end

    local currentWeight = obj:GetAttribute("FruitWeight") or obj:GetAttribute("PlantWeight") or 0
    if Collect_MinWeight > 0 and currentWeight < Collect_MinWeight then return end

    local cleanName = parentName:gsub("%d+", "")
    local typeMatch = table.find(Collect_Plants, "All")
    if not typeMatch then
        for _, p in pairs(Collect_Plants) do
            if string.find(cleanName:lower(), p:lower()) then typeMatch = true break end
        end
    end
    if not typeMatch then return end

    local hasMutFilter = #Filter_Mutations > 0
    local hasRipeFilter = #Filter_Ripeness > 0
    local hasVarFilter = #Filter_Variants > 0

    if not (hasMutFilter or hasRipeFilter or hasVarFilter) then
        HarvestTarget(obj, parentName)
    else
        local mutAttr = tostring(obj:GetAttribute("Mutation") or ""):lower()
        local ripeAttr = tostring(obj:GetAttribute("RipenessStage") or ""):lower()
        local varAttr = tostring(obj:GetAttribute("Variant") or ""):lower()
        
        local isTarget = false
        for _, f in pairs(Filter_Mutations) do
            if mutAttr ~= "" and string.find(mutAttr, f:lower()) then isTarget = true break end
        end
        if not isTarget then
            for _, f in pairs(Filter_Ripeness) do
                if ripeAttr ~= "" and string.find(ripeAttr, f:lower()) then isTarget = true break end
            end
        end
        if not isTarget then
            for _, f in pairs(Filter_Variants) do
                if varAttr ~= "" and string.find(varAttr, f:lower()) then isTarget = true break end
            end
        end

        if isTarget then HarvestTarget(obj, parentName) end
    end
end

-- 4. SCANNER LOOP
task.spawn(function()
    while true do
        if AutoCollect_Enabled then
            local plants = workspace.ClientPlants:GetChildren()
            for _, item in pairs(plants) do
                if not AutoCollect_Enabled then break end
                local fruitsFound = false
                for _, child in pairs(item:GetChildren()) do
                    if string.find(child.Name, "Fruit") then
                        fruitsFound = true
                        ProcessCollect(child, item.Name)
                    end
                end
                if not fruitsFound then ProcessCollect(item, item.Name) end
            end
        end
        task.wait(0.5) 
    end
end)

ESP:CreateSection("AUTO SHOVEL")

-- Variables
local targetPlant = nil
local selectedVariant = "None" 
local targetKg = 0
local autoFarmEnabled = false
local currentHighlight = nil
local selecting = false

-- Utility: Clean UUID
local function cleanUuid(uuid)
    if not uuid then return nil end
    return string.split(tostring(uuid), ":")[1]
end

-- Status Label
local StatusLabel = ESP:CreateLabel("Selected Plant: None")

-- Selection & Deselection Logic
local function startSelection()
    selecting = true
    Rayfield:Notify({Title = "Selection", Content = "Click a plant to Select/Unselect it!", Duration = 5})
    
    local mouse = game.Players.LocalPlayer:GetMouse()
    local connection
    connection = mouse.Button1Down:Connect(function()
        local target = mouse.Target
        if target and target:IsDescendantOf(workspace.ClientPlants) then
            -- Find the Top-Level Parent
            local plantObj = target
            while plantObj.Parent ~= workspace.ClientPlants do
                plantObj = plantObj.Parent
            end
            
            -- If clicking the SAME plant, Unselect it
            if targetPlant == plantObj then
                targetPlant = nil
                StatusLabel:Set("Selected Plant: None")
                if currentHighlight then 
                    currentHighlight:Destroy() 
                    currentHighlight = nil
                end
                Rayfield:Notify({Title = "Unselected", Content = "Target cleared.", Duration = 3})
            else
                -- Select new plant
                targetPlant = plantObj
                StatusLabel:Set("Selected Plant: " .. targetPlant.Name)
                if currentHighlight then currentHighlight:Destroy() end
                
                local highlight = Instance.new("Highlight")
                highlight.Parent = targetPlant
                highlight.FillColor = Color3.fromRGB(0, 255, 0)
                currentHighlight = highlight
                
                Rayfield:Notify({Title = "Selected", Content = "Target: " .. targetPlant.Name, Duration = 3})
            end
            
            selecting = false
            connection:Disconnect()
        end
    end)
end

-- Main Farm Loop
task.spawn(function()
