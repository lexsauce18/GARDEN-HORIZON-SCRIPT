-- 2. ENHANCED REMOTE HARVESTING ENGINE (UPDATED TO UUID METHOD)
local function HarvestTarget(targetObj, parentName)
    local p = game.Players.LocalPlayer
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    -- Get the Uuid from the object attributes as seen in your image
    local plantUuid = targetObj:GetAttribute("Uuid")
    if not plantUuid then return end

    -- Find Anchor (Crops use PlantAnchor, Trees use FruitAnchor)
    local anchor = targetObj:FindFirstChild("PlantAnchor") or targetObj:FindFirstChild("FruitAnchor")
    if not anchor and targetObj.Parent then
        anchor = targetObj.Parent:FindFirstChild("PlantAnchor") or targetObj.Parent:FindFirstChild("FruitAnchor")
    end
    
    if anchor then
        -- 1. Precision Teleport
        char.HumanoidRootPart.CFrame = CFrame.new(anchor.Position + Vector3.new(0, 1.5, 2), anchor.Position)
        
        -- 2. New Remote Fire Method using Uuid Table
        task.wait(0.1)
        local args = {
            {
                {
                    Uuid = plantUuid
                }
            }
        }
        HarvestRemote:FireServer(unpack(args))
        
        -- 3. Short stability wait
        task.wait(0.2) 
    end
end

-- 3. VALIDATION LOGIC
local function ProcessCollect(obj, parentName)
    -- Image checks: FullyGrown and not Favorited
    if obj:GetAttribute("FullyGrown") ~= true then return end
    if obj:GetAttribute("Favorited") == true then return end

    -- Weight Check
    local currentWeight = obj:GetAttribute("FruitWeight") or obj:GetAttribute("PlantWeight") or 0
    if Collect_MinWeight > 0 and currentWeight < Collect_MinWeight then return end

    local cleanName = parentName:gsub("%d+", "")
    
    -- Plant Type Match
    local typeMatch = table.find(Collect_Plants, "All")
    if not typeMatch then
        for _, p in pairs(Collect_Plants) do
            if string.find(cleanName:lower(), p:lower()) then typeMatch = true break end
        end
    end
    if not typeMatch then return end

    -- Mutation Logic
    local mutationCount = 0
    for _ in pairs(Collect_Mutations) do mutationCount = mutationCount + 1 end

    if mutationCount == 0 then
        -- Collect all of type
        HarvestTarget(obj, parentName)
    else
        local mut = tostring(obj:GetAttribute("Mutation") or ""):lower()
        local ripe = tostring(obj:GetAttribute("RipenessStage") or ""):lower()
        local var = tostring(obj:GetAttribute("Variant") or ""):lower()
        
        local mutMatched = false
        for _, selected in pairs(Collect_Mutations) do
            local f = selected:lower()
            if (mut ~= "" and string.find(mut, f)) or 
               (ripe ~= "" and string.find(ripe, f)) or 
               (var ~= "" and string.find(var, f)) then
                mutMatched = true
                break
            end
        end

        if mutMatched then 
            HarvestTarget(obj, parentName) 
        end
    end
end

-- 4. SCANNER LOOP
task.spawn(function()
    while true do
        if AutoCollect_Enabled then
            local plants = workspace.ClientPlants:GetChildren()
            for _, item in pairs(plants) do
                if not AutoCollect_Enabled then break end
                
                local fruitsFound = false
                -- Check for Tree Fruits
                for _, child in pairs(item:GetChildren()) do
                    if string.find(child.Name, "Fruit") then
                        fruitsFound = true
                        ProcessCollect(child, item.Name)
                    end
                end

                -- Standard Crop
                if not fruitsFound then
                    ProcessCollect(item, item.Name)
                end
            end
        end
        task.wait(0.5) 
    end
end)

