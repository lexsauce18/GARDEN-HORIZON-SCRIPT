                    local rangeSize = getLiveRange(sName)
                    data.marker.Size = Vector3.new(0.05, rangeSize, rangeSize)
                    data.marker.Color = Color3.fromRGB(255, 0, 0)
                end
            end
        end

        if selection == "All" then
            for i = 1, #SelectedLocations do applySettings(i) end
        elseif tonumber(selection) then
            applySettings(tonumber(selection))
        end
    end,
})

