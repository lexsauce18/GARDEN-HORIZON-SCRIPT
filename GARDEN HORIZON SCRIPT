-- Helper to check stock via UI Text
local function GetStock(seedName)
    local success, stockLabel = pcall(function()
        return ShopGui.Frame.ScrollingFrame[seedName].MainInfo.StockText
    end)
    
    if success and stockLabel then
        local stockAmount = string.match(stockLabel.Text, "%d+")
        return tonumber(stockAmount) or 0
    end
    return 0
end

-- SMART BLINK Purchase Logic
local function PerformPurchase(seedList, toggleFlag)
    local character = Player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    
    if not hrp or #seedList == 0 then return end

    local itemsToBuy = {}
    for _, name in pairs(seedList) do
        if GetStock(name) > 0 then
            table.insert(itemsToBuy, name)
        end
    end

    if #itemsToBuy > 0 then
        local lastLocation = hrp.CFrame
        hrp.CFrame = CFrame.new(ShopCoords)
        task.wait(0.3)

        for _, name in pairs(itemsToBuy) do
            if not _G[toggleFlag] then break end
            local itemName = name .. " Seed"
            while _G[toggleFlag] and GetStock(name) > 0 do
                PurchaseRemote:InvokeServer("SeedShop", itemName)
                task.wait(0.01) 
            end
        end
        hrp.CFrame = lastLocation
    end
end

