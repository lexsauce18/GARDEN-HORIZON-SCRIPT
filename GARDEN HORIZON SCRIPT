-- OPTIMIZED SCANNER ENGINE
-- ==========================================
task.spawn(function()
    while true do
        if Master_ESP_Enabled then
            local plants = workspace.ClientPlants:GetChildren()
            for _, item in pairs(plants) do
                local hasFruits = false
                for _, child in pairs(item:GetChildren()) do
                    if string.find(child.Name, "Fruit") then
                        hasFruits = true
                        ProcessCombined(child, item.Name)
                    end
                end
                
                if not hasFruits then
                    ProcessCombined(item, item.Name)
                end
            end
        end
        task.wait(0.5) 
    end
end)

