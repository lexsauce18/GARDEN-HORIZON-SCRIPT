local GearSection = GameTab:CreateSection("Auto Buy Gear")
local SelectedGears = {}
local GearAutoBuyEnabled = false
local ShopCFrame = CFrame.new(211.40, 204.01, 608.80)

local function GetGearStockCount()
    local totalStock = 0
    local scrollingFrame = Player.PlayerGui.GearShop.Frame.ScrollingFrame
    
    for _, gearName in ipairs(SelectedGears) do
        local gearPath = scrollingFrame:FindFirstChild(gearName)
        if gearPath and gearPath.MainInfo:FindFirstChild("StockText") then
            local text = gearPath.MainInfo.StockText.Text
            local stockNum = tonumber(string.match(text, "%d+")) or 0
            if stockNum > 0 then
                totalStock = totalStock + stockNum
            end
        end
    end
    return totalStock
end

local function RunGearOneBlinkBuy()
    local char = Player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    local root = char.HumanoidRootPart
    local scrollingFrame = Player.PlayerGui.GearShop.Frame.ScrollingFrame
    
    if GetGearStockCount() > 0 then
        local originalPos = root.CFrame
        root.CFrame = ShopCFrame
        task.wait(0.2)
        
        while GearAutoBuyEnabled and GetGearStockCount() > 0 do
            for _, gearName in ipairs(SelectedGears) do
                local gearPath = scrollingFrame:FindFirstChild(gearName)
                if gearPath then
                    local stockNum = tonumber(string.match(gearPath.MainInfo.StockText.Text, "%d+")) or 0
                    if stockNum > 0 then
                        pcall(function()
                            PurchaseRemote:InvokeServer("GearShop", gearName)
                        end)
                    end
                end
            end
            task.wait(0.1)
        end
        root.CFrame = originalPos
    end
end

