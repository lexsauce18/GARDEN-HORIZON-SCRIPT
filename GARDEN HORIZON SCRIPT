local ActiveObjects = {}
local Master_ESP_Enabled = false 

local function ClearESP(obj)
    if ActiveObjects[obj] then
        for _, v in pairs(ActiveObjects[obj]) do
            if v then v:Destroy() end
        end
        ActiveObjects[obj] = nil
    end
end

-- ==========================================
-- COMBINED ESP ENGINE (FIXED MUTATION FILTERING)
-- ==========================================
ESP:CreateSection("ESP MASTER CONTROL")

local SelectedMutations = {}
local SelectedWeightPlants = {}

local function ApplyCombinedESP(target, labelText, isMutation)
    if ActiveObjects[target] then 
        local billboard = ActiveObjects[target][2]
        if billboard and billboard:FindFirstChild("TextLabel") then
            billboard.TextLabel.Text = labelText
        end
        return 
    end

    local highlight = Instance.new("Highlight")
    highlight.Adornee = target
    -- Yellow if mutation found, Cyan if only weight
    highlight.FillColor = isMutation and Color3.fromRGB(255, 255, 0) or Color3.fromRGB(0, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.Parent = target
    
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 250, 0, 50) 
    billboard.AlwaysOnTop = true
    billboard.ExtentsOffset = Vector3.new(0, 0, 0) 
    billboard.Adornee = target
    billboard.Parent = target
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(255, 255, 255) 
    label.TextStrokeTransparency = 0.3
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 12
    label.Parent = billboard
    ActiveObjects[target] = {highlight, billboard}
end

local function ProcessCombined(obj, displayName)
    if not Master_ESP_Enabled then return end
    
    local cleanName = displayName:gsub("%d+", "")
    
    -- 1. Check Mutation Logic (STRICT FILTERING)
    local mutAttr = obj:GetAttribute("Mutation")
    local ripeAttr = obj:GetAttribute("RipenessStage")
    local varAttr = obj:GetAttribute("Variant")
    
    local foundTraits = {}
    local mutMatched = false

    -- Only add traits to the label if they are in the SelectedMutations list
    for _, filterName in pairs(SelectedMutations) do
        local f = filterName:lower()
        
        if mutAttr and tostring(mutAttr):lower() == f then
            if not table.find(foundTraits, tostring(mutAttr)) then table.insert(foundTraits, tostring(mutAttr)) end
            mutMatched = true
        end
        if ripeAttr and tostring(ripeAttr):lower() == f then
            if not table.find(foundTraits, tostring(ripeAttr)) then table.insert(foundTraits, tostring(ripeAttr)) end
            mutMatched = true
        end
        if varAttr and tostring(varAttr):lower() == f then
            if not table.find(foundTraits, tostring(varAttr)) then table.insert(foundTraits, tostring(varAttr)) end
            mutMatched = true
        end
    end

    -- 2. Check Weight Logic (UNCHANGED)
    local weightAttr = obj:GetAttribute("PlantWeight") or obj:GetAttribute("FruitWeight")
    local weightMatched = false
    if weightAttr then
        if table.find(SelectedWeightPlants, "All") then
            weightMatched = true
        else
            for _, p in pairs(SelectedWeightPlants) do
                if string.find(cleanName:lower(), p:lower()) then weightMatched = true break end
            end
        end
    end

    -- 3. Combine Display
    if mutMatched or weightMatched then
        local finalLabel = "[" .. cleanName .. "]: "
        
        -- Only show Mutation brackets if a selected mutation was found
        if mutMatched and #foundTraits > 0 then
            finalLabel = finalLabel .. "[" .. table.concat(foundTraits, ",") .. "] "
        end
        
        -- Add Weight part if matched
        if weightMatched then
            local rounded = math.floor(tonumber(weightAttr) * 100 + 0.5) / 100
            finalLabel = finalLabel .. "[" .. tostring(rounded) .. " kg]"
        end
        
        ApplyCombinedESP(obj, finalLabel, mutMatched)
    else
        ClearESP(obj)
    end
end

