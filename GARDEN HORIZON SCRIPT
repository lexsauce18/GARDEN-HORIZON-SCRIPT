-- [[ CORE FUNCTIONS ]]

local function getLiveRange(sprinklerName)
    local success, result = pcall(function()
        local emitter = workspace.ClientSprinklers:FindFirstChild(sprinklerName).GroundAnchor.PreviewOutline.ParticleEmitter
        return emitter.Size.Keypoints[1].Value * 2.2 
    end)
    if success and result then return result end
    return FallbackRanges[sprinklerName] or 2.5
end

local function createMarker(pos, num)
    local part = Instance.new("Part")
    part.Name = "AlphaHub_Circle_" .. num
    part.Shape = Enum.PartType.Cylinder
    part.Size = Vector3.new(0.05, 2.5, 2.5) 
    part.Rotation = Vector3.new(0, 0, 90)
    part.Position = pos + Vector3.new(0, 0.05, 0)
    part.Anchored = true
    part.CanCollide = false
    part.Transparency = 0.5
    part.Material = Enum.Material.Neon
    part.Color = Color3.fromRGB(0, 255, 150)
    part.Parent = workspace
    
    local textAnchor = Instance.new("Part")
    textAnchor.Name = "AlphaHub_TextAnchor_" .. num
    textAnchor.Size = Vector3.new(1, 1, 1)
    textAnchor.Position = pos + Vector3.new(0, 4, 0)
    textAnchor.Anchored = true
    textAnchor.CanCollide = false
    textAnchor.Transparency = 1
    textAnchor.Parent = workspace
    
    local billboard = Instance.new("BillboardGui", textAnchor)
    billboard.Name = "InfoUI"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 150, 0, 75)
    
    local text = Instance.new("TextLabel", billboard)
    text.Size = UDim2.new(1, 0, 1, 0)
    text.BackgroundTransparency = 1
    text.TextColor3 = Color3.new(1, 1, 1)
    text.TextStrokeTransparency = 0
    text.TextStrokeColor3 = Color3.new(0, 0, 0)
    text.Text = "Slot " .. num .. "\nReady"
    text.TextScaled = true
    
    return part, text, textAnchor
end

