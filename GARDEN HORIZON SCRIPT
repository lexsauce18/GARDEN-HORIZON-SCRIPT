    CurrentOption = {"None"},
    Callback = function(Option)
        local selection = LocDropdown.CurrentOption[1]
        local sName = Option[1]
        
        local function applySettings(idx)
            local data = SelectedLocations[idx]
            if data then
                data.sprinklerType = sName
                data.duration = SprinklerSettings[sName].Timer
                data.label.Text = sName == "None" and "Slot "..idx.."\n[Disabled]" or "Slot "..idx.."\n"..sName
                
