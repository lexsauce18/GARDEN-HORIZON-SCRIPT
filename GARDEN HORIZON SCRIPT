-- ==========================================
-- COMBINED ESP ENGINE (STRICT LABEL FILTERING)
-- ==========================================
ESP:CreateSection("ESP CONTROLS")

local SelectedMutations = {}
local SelectedPlantTypes = {}

local function ApplyCombinedESP(target, labelText, isMutation)
    if ActiveObjects[target] then 
        local billboard = ActiveObjects[target][2]
        if billboard and billboard:FindFirstChild("TextLabel") then
            billboard.TextLabel.Text = labelText
        end
        return 
    end

    local highlight = Instance.new("Highlight")
    highlight.Adornee = target
    highlight.FillColor = isMutation and Color3.fromRGB(255, 255, 0) or Color3.fromRGB(0, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.Parent = target
    
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 250, 0, 50) 
    billboard.AlwaysOnTop = true
    billboard.ExtentsOffset = Vector3.new(0, 0, 0) 
    billboard.Adornee = target
    billboard.Parent = target
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(255, 255, 255) 
    label.TextStrokeTransparency = 0.3
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 12
    label.Parent = billboard
    ActiveObjects[target] = {highlight, billboard}
end

local function ProcessCombined(obj, displayName)
    local cleanName = displayName:gsub("%d+", "")
    
    -- 1. Main Plant Type Filter
    local plantMatched = false
    if #SelectedPlantTypes == 0 or table.find(SelectedPlantTypes, "All") then
        plantMatched = true
    else
        for _, p in pairs(SelectedPlantTypes) do
            if string.find(cleanName:lower(), p:lower()) then plantMatched = true break end
        end
    end

    if not plantMatched then 
        ClearESP(obj)
        return 
    end

    -- 2. Selective Mutation Logic
    local displayTraits = {}
    local mutMatched = false

    if Mutation_ESP_Enabled then
        local mutAttr = tostring(obj:GetAttribute("Mutation") or ""):lower()
        local ripeAttr = tostring(obj:GetAttribute("RipenessStage") or ""):lower()
        local varAttr = tostring(obj:GetAttribute("Variant") or ""):lower()
        
        -- We only add the trait to displayTraits if the PLAYER selected it
        for _, filterName in pairs(SelectedMutations) do
            local f = filterName:lower()
            
            if (mutAttr ~= "" and string.find(mutAttr, f)) or 
               (ripeAttr ~= "" and string.find(ripeAttr, f)) or 
               (varAttr ~= "" and string.find(varAttr, f)) then
                
                -- Only insert the specific filter name selected by the player
                if not table.find(displayTraits, filterName) then
                    table.insert(displayTraits, filterName)
                end
                mutMatched = true
            end
        end
    end

    -- 3. Weight Logic
    local weightAttr = obj:GetAttribute("PlantWeight") or obj:GetAttribute("FruitWeight")
    local weightMatched = Weight_ESP_Enabled and weightAttr ~= nil

    -- 4. Final Display Logic
    if mutMatched or weightMatched then
        local finalLabel = "[" .. cleanName .. "]: "
        
        -- Strict Mutation Display: Only shows what was checked in the menu
        if mutMatched and #displayTraits > 0 then
            finalLabel = finalLabel .. "[" .. table.concat(displayTraits, ",") .. "] "
        end
        
        if weightMatched then
            local rounded = math.floor(tonumber(weightAttr) * 100 + 0.5) / 100
            finalLabel = finalLabel .. "[" .. tostring(rounded) .. " kg]"
        end
        
        ApplyCombinedESP(obj, finalLabel, mutMatched)
    else
        ClearESP(obj)
    end
end

