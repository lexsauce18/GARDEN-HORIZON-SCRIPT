--- ESP SECTION (REWORKED FOR GLOBAL POV) ---
GameTab:CreateSection("ESP FILTERS")

local ESP_Enabled = false
local SelectedMutations = {}
local ActiveObjects = {}

local function RemoveESP(obj)
    if ActiveObjects[obj] then
        for _, v in pairs(ActiveObjects[obj]) do
            if v then v:Destroy() end
        end
        ActiveObjects[obj] = nil
    end
end

local function ApplyESP(target, matchedKeyword)
    if ActiveObjects[target] then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "AlphaHighlight"
    highlight.Adornee = target
    highlight.FillColor = Color3.fromRGB(255, 255, 0) 
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = target
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "AlphaLabel"
    billboard.Size = UDim2.new(0, 150, 0, 50)
    billboard.AlwaysOnTop = true
    billboard.ExtentsOffset = Vector3.new(0, 2, 0)
    billboard.Adornee = target
    billboard.Parent = target
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = "[" .. matchedKeyword:upper() .. "]"
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextStrokeTransparency = 0
    label.Font = Enum.Font.GothamBold
    label.TextSize = 14
    label.Parent = billboard
    
    ActiveObjects[target] = {highlight, billboard}
end

local function ProcessESPObject(obj)
    -- Gather all attributes from the multiple sections found in your images
    local mutVal = tostring(obj:GetAttribute("Mutation") or ""):lower()
    local ripeVal = tostring(obj:GetAttribute("RipenessStage") or ""):lower()
    local variantVal = tostring(obj:GetAttribute("Variant") or ""):lower()

    local isMatched = false
    local keywordFound = ""

    for _, m in pairs(SelectedMutations) do
        local filter = m:lower()
        if string.find(mutVal, filter) or string.find(ripeVal, filter) or string.find(variantVal, filter) then
            isMatched = true
            keywordFound = m
            break
        end
    end

    if isMatched then
        ApplyESP(obj, keywordFound)
    else
        RemoveESP(obj)
    end
end

local function ScanClientPlants()
    if not ESP_Enabled then return end
    for _, item in pairs(workspace.ClientPlants:GetChildren()) do
        ProcessESPObject(item)
        for _, child in pairs(item:GetChildren()) do
            if string.find(child.Name, "Fruit") then
                ProcessESPObject(child)
            end
        end
    end
end

-- Refresh Loop (Global Search)
task.spawn(function()
    while true do
        if ESP_Enabled then
            ScanClientPlants()
        end
        task.wait(1.5)
    end
end)

