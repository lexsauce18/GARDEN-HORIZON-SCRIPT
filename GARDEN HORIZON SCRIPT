local AutomationTab = Window:CreateTab("Event", 4483345998)

local EventSection = AutomationTab:CreateSection("Auto Collect Manny Fruits")
local AutoCollect = false
local WorkspaceListener = nil

-- The main collection logic
local function StartCollectionProcess(folder)
    while AutoCollect and folder and folder.Parent do
        local items = folder:GetChildren()
        
        if #items == 0 then 
            task.wait(1) 
        else
            for _, item in ipairs(items) do
                if not AutoCollect then break end
                
                local targetPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
                
                if targetPart then
                    -- 1. WAIT FOR FRUIT TO REACH GROUND
                    -- We check if the velocity is near zero or if the fruit has landed
                    local timeout = 0
                    while targetPart.AssemblyLinearVelocity.Magnitude > 0.1 and timeout < 5 do
                        task.wait(0.1)
                        timeout = timeout + 0.1
                    end

                    local player = game.Players.LocalPlayer
                    local char = player.Character
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        -- Teleport to the fruit
                        char.HumanoidRootPart.CFrame = targetPart.CFrame
                        
                        -- Wait until this specific fruit is gone before moving to the next
                        repeat task.wait(0.1) until not item:IsDescendantOf(workspace) or not AutoCollect
                        
                        -- 2. WAIT 0.5 SECONDS EVERY FRUIT
                        task.wait(0.5)
                    end
                end
            end
        end
        task.wait(0.5)
    end
end

