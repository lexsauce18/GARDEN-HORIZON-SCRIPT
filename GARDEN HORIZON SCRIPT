UserInputService.InputBegan:Connect(function(input, processed)
    if processed or not SelectionPending then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local target = Mouse.Target
        if target and (target.Name == "PlantableArea" or target:IsDescendantOf(workspace.Plots)) then
            SelectionPending = false
            local pos = Mouse.Hit.p
            local index = #SelectedLocations + 1
            local marker, label, anchor = createMarker(pos, index)
            table.insert(SelectedLocations, {
                pos = pos, marker = marker, label = label, anchor = anchor,
                sprinklerType = "None", duration = 999999, lastPlaced = 0
            })
            local list = {"None", "All"}
            for i = 1, #SelectedLocations do table.insert(list, tostring(i)) end
            LocDropdown:Refresh(list)
        end
    end
end)

-- [[ DEPLOYMENT ENGINE WITH SLOW STAGGER ]]

task.spawn(function()
    while true do
        if AutoPlaceEnabled then
            for i = 1, #SelectedLocations do
                local data = SelectedLocations[i]
                
                if data and data.sprinklerType ~= "None" then
                    local currentTime = tick()
                    
                    if (currentTime - data.lastPlaced) >= data.duration then
                        -- Fire remote
                        UseGearRemote:FireServer(data.sprinklerType, { position = data.pos })
                        data.lastPlaced = currentTime
                        
                        -- Timer Visuals
                        task.spawn(function()
                            for t = data.duration, 0, -1 do
                                if not AutoPlaceEnabled or not SelectedLocations[i] or data.sprinklerType == "None" then break end
                                data.label.Text = string.format("Slot %d\n%s\n%02d:%02d", i, data.sprinklerType, math.floor(t/60), t%60)
                                task.wait(1)
                            end
                            if SelectedLocations[i] then data.label.Text = "Slot "..i.."\nReady" end
                        end)
                        
                        -- THE COOLDOWN FIX: Wait 1.5 seconds before moving to the next slot
                        -- This prevents the game from blocking the second and third sprinkler
                        task.wait(1.6) 
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)

